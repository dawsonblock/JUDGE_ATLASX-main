{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "postgresAdminPassword": {
      "value": "${AZURE_POSTGRES_ADMIN_PASSWORD}"
    },
    "jwtSecret": {
      "value": "${AZURE_JWT_SECRET}"
    },
    "enableAdminReview": {
      "value": "${AZURE_ENABLE_ADMIN_REVIEW=false}"
    },
    "enableAdminImports": {
      "value": "${AZURE_ENABLE_ADMIN_IMPORTS=false}"
    },
    "corsOrigins": {
      "value": "${AZURE_CORS_ORIGINS}"
    }
  }
}
