# ---- Non-shipping / reference trees (HARD-ENFORCED) -------------------------
# These directories MUST NOT be tracked, committed, or shipped.
# They contain third-party research repos, vendored deps, or dev tooling.
# None of these must contain runtime product code or secrets.
research/
external/
external_reference/
Research /
Research/
external_reference/
docs/reference/archived/
docs/reference/vendor_repos/
docs/reference/experiments/

# Exclude any local builds that may be produced inside research subtrees
research/**/__pycache__/
research/**/.pytest_cache/
research/**/.mypy_cache/
research/**/.ruff_cache/
research/**/*.py[cod]
research/**/node_modules/
research/**/.next/
external/**/__pycache__/
external/**/*.py[cod]
external/**/node_modules/
